    'side: ["RIGHT", "LEFT"] '
    'direction: ["INWARD", "OUTWARD"] '
    'origin: { "x": < float >, "y": < float >, "z": < float > }, '
    'dimensions: { "width": < float >, "height": < float >, "depth": 0.01 }, '
    'arch_shape (for arched openings only): ["SEMI", "QUARTER"], '
    'orientation (for QUARTER arches only): ["TL", "TR", "BL", "BR"], '
    "radius (for arches): < float, feet >. "
    "id : ${type}_${side}${host_id} "
    "host_id : id of host element "
    "Category x Type Map "
    'STRUCTURE: ["BEAM", "COLUMN", "DOOR_RECT", "DOOR_ARCH", "ARCH_OPENING", "MAIN_WALL", "RETURN_WALL", "WINDOW"] '
    'ELECTRICAL: ["SWITCH_BOARD", "AC"] '
    "REQUIRED EXAMPLE JSON OUTPUT FORMAT "
    '{ "elements": [ '
    '{ "id": "MAIN_WALL", "category": "STRUCTURE", "type": "MAIN_WALL", '
    '"origin": { "x": 0, "y": 0, "z": 0 }, '
    '"dimensions": { "width": 0, "height": 0, "depth": 0.75 } }, '
